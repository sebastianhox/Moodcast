+    fun getFutureWeather(day: Int) {
+        val timeseries = alertUiState.value.weatherAlerts
+
+
+        val futureWeather = LocalDate.now().plusDays(day.toLong())
+        val futureDateString = futureWeather.toString()
+
+        var weatherDataForTomorrow: Timeseries? = null
+        timeseries?.forEach { ts ->
+            if (ts.time?.startsWith(futureDateString) == true) {
+                weatherDataForTomorrow = ts
+                return@forEach
+            }
+        }
